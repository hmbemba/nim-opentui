# Upstream OpenTUI library (submodule or vendored)
opentui/

# Agent workflow database and outputs
agent.db
subagents/
finalOutput.md
plan.md

# =============================================================================
# Nim-specific ignores
# =============================================================================

# Nim cache directories
nimcache/
.nimcache/
cache/

# Compiled binaries (when built at root)
*.exe
*.dll
*.so
*.dylib
*.a
*.lib

# Test binaries
tests/*.exe
tests/*.dll

# Build output
build/
dist/
out/

# =============================================================================
# Editor and IDE
# =============================================================================

# VS Code
.vscode/
*.code-workspace

# IntelliJ / JetBrains
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo
*~
Session.vim
.netrwhist

# Emacs
*~
\#*\#
.\#*

# Sublime Text
*.sublime-workspace
*.sublime-project

# =============================================================================
# OS-specific files
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.nfs*
.directory
.Trash-*

# =============================================================================
# Logs and temporary files
# =============================================================================

*.log
logs/
tmp/
temp/
*.tmp
*.bak
*.backup

# =============================================================================
# Environment and secrets
# =============================================================================

.env
.env.*
!.env.example
*.pem
*.key
secrets/

# =============================================================================
# Package manager artifacts (if any)
# =============================================================================

# Node (if any JS tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python (if any scripts)
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.venv/
venv/

# Zig (for the native library builds in vendor)
zig-cache/
zig-out/
